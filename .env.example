# macOS code signing + notarization — copy to `.env` and fill in.
# `.env` is gitignored. See docs/RELEASE.md for the full runbook.

# --- Code signing (required to sign) ---
# Must match a "Developer ID Application" cert in your login keychain:
#   security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Lean Code Automation LLC (PMNAQBZ3KN)"

# --- Notarization, Option A: Apple ID + app-specific password (simplest) ---
# Create an app-specific password at https://appleid.apple.com → Sign-In & Security.
APPLE_ID="you@example.com"
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="PMNAQBZ3KN"

# --- Notarization, Option B: App Store Connect API key (alternative) ---
# Leave the Apple ID vars above blank if you use these instead.
# APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
# APPLE_API_KEY="XXXXXXXXXX"
# APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"

# --- Updater signing (required to produce auto-update artifacts) ---
# Generate once with: npx tauri signer generate -w ~/.tauri/agent-status-updater.key
# The PUBLIC key (.pub) goes in src-tauri/tauri.conf.json; the PRIVATE key signs builds.
# TAURI_SIGNING_PRIVATE_KEY accepts either the key's path or its base64 contents.
TAURI_SIGNING_PRIVATE_KEY="/Users/you/.tauri/agent-status-updater.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""
